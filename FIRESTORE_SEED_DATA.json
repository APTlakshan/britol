/*
═══════════════════════════════════════════════════════════════
   HOW TO IMPORT THIS DATA INTO FIRESTORE
═══════════════════════════════════════════════════════════════

METHOD 1: Manual Entry (via Firebase Console)
───────────────────────────────────────────────
1. Go to https://console.firebase.google.com
2. Select "britoldata" project
3. Click on "Firestore Database"
4. Click "Start Collection"
5. Collection ID: "config"
6. Click "Auto ID" or leave blank for first doc
7. Manually enter each field:
   - Field name: "items"
   - Type: "Array"
   - Add array items manually

Alternative - Use "Import Document":
1. Click "Import Document" button
2. Select JSON file
3. Map fields appropriately

METHOD 2: Firebase CLI (Command Line)
──────────────────────────────────────
# Install Firebase CLI
npm install -g firebase-tools

# Login to Firebase
firebase login

# Set project
firebase use britoldata

# Use firestore:import command
firebase firestore:import --import-path=backup.json --project=britoldata

METHOD 3: Via Admin SDK (Node.js)
──────────────────────────────────
const admin = require('firebase-admin');
const serviceAccount = require('./serviceAccountKey.json');

admin.initializeApp({
  credential: admin.credential.cert(serviceAccount),
  projectId: 'britoldata'
});

const db = admin.firestore();

// Create or update config/services
await db.collection('config').doc('services').set({
  items: [...data...]
});

// Repeat for other documents


